# Environment Configuration Template
# Copy this file to .env and fill in values before running locally

# Flask secret key (generate: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production

# Groq API key for AI chat (free at https://console.groq.com)
# Without this, chat falls back to smart rule-based responses
GROQ_API_KEY=your_groq_api_key_here

# Optional: Port override (default: 8080)
PORT=8080

# Email Notifications (SMTP configuration)
# Required for sending budget alerts over email
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=rushikeshkuwar896@gmail.com
SMTP_PASSWORD=jzma uiid vyyr gvhr
